{
  "version": "2",
  "sql": [
    {
      "schema": "./db/schema",
      "queries": "./db/query",
      "engine": "postgresql",
      "gen": {
        "go": {
          "package": "sqlc",
          "out": "./db/sqlc",
          "emit_json_tags": true,
          "emit_prepared_queries": false,
          "emit_exact_table_names": false,
          "emit_pointers_for_null_types": false,
          "emit_empty_slices": true,
          "emit_interface": false,
          "overrides": [
            {
              "db_type": "pg_catalog.int8",
              "go_type": "string"
            },
            {
              "db_type": "numeric",
              "go_type": "string"
            }
          ]
        }
      }
    }
  ]
}
